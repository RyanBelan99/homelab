apiVersion: v1
kind: Secret
metadata:
  name: samba-config
  namespace: nas
type: Opaque
stringData:
  # Account inside the container; UID 1000 matches the owner of the NAS files on the host.
  # Copy this file to 10-secret.yaml and set a real password.
  ACCOUNT_rbelan: "CHANGEME"
  UID_rbelan: "1000"
  SAMBA_VOLUME_CONFIG_networkstorage: "[NetworkStorage]; path=/shares/nas; valid users = rbelan; guest ok = no; read only = no; browseable = yes; create mask = 0777; directory mask = 0777"
